# Competitive Intelligence Agent — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Who receives the weekly report
EMAIL_TO=you@yourcompany.com

# SMTP settings
# For Gmail: use smtp.gmail.com + an App Password (not your real password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password-here

# Optional: override the From address (defaults to SMTP_USER)
# EMAIL_FROM=alerts@yourcompany.com
